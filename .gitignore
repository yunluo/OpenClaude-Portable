# ── Generated / downloaded binaries ──────────────────────────────
/engine/
/Windows/bin/
/Linux/bin/
/Mac/bin/

# ── Personal data (API keys, chats, logs) ─────────────────────────
/data/

# ── Bun cache ────────────────────────────────────────────────────
